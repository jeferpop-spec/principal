# Arquivo de exemplo das variáveis de ambiente necessárias
# Copie este arquivo para .env e preencha com suas credenciais do Supabase

# URL do seu projeto Supabase
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anônima do Supabase (public key)
VITE_SUPABASE_ANON_KEY=sua-chave-anonima-aqui